# Snapshot configuration — copy to `.snapshot.yaml` (git-ignored) and adjust.
# Anything sensitive (hosts, users, paths, IPs, credentials) belongs in `.env` and is
# referenced here via %env(...)%. This file holds structure only and is safe to commit
# in a redacted form.

environments:
  live:
    transport: ssh          # ssh (v1) | kubectl (planned)
    host: "%env(SNAP_LIVE_HOST)%"
    user: "%env(SNAP_LIVE_USER)%"
    port: 22
    path: "%env(SNAP_LIVE_PATH)%"     # absolute path to the TYPO3 project root on the server
    file_source: rsync      # rsync (v1) | s3 (planned)

  stage:
    transport: ssh
    host: "%env(SNAP_STAGE_HOST)%"
    user: "%env(SNAP_STAGE_USER)%"
    port: 22
    path: "%env(SNAP_STAGE_PATH)%"
    file_source: rsync
    # Optional explicit database connection. Recommended for the common hosting setup where
    # the real credentials come from web-context environment variables (via additional.php)
    # and are NOT present in the SSH shell — in that case reading settings.php is not enough.
    # If omitted, Snapshot tries to read the connection from the remote settings.php.
    db:
      host: "%env(SNAP_STAGE_DB_HOST)%"
      port: 3306
      name: "%env(SNAP_STAGE_DB_NAME)%"
      user: "%env(SNAP_STAGE_DB_USER)%"
      password: "%env(SNAP_STAGE_DB_PASSWORD)%"

defaults:
  # GDPR anonymization is ON by default. Never disable it for a production source without
  # a very good reason.
  scrub: true

  # Tables never worth transferring (regenerable / noise).
  db_exclude:
    - "cache_*"
    - "[bf]e_sessions"
    - "sys_log"
    - "sys_history"
    - "sys_file_processedfile"

  # fileadmin paths skipped during rsync (regenerable).
  rsync_excludes:
    - "_processed_/**"
    - "_temp_/**"

  # Extra/override anonymization rules, merged over the built-in defaults (fe_users, sys_log).
  # Each table is either truncated or has columns overwritten. Use {uid} for per-row uniqueness.
  scrub_rules:
    tx_myshop_domain_model_order:
      truncate: true
    fe_users:
      set:
        email: "user{uid}@example.invalid"
        username: "user{uid}"

  # Steps run automatically after a successful pull, to make the site immediately runnable.
  post_pull:
    - cache_flush
    - referenceindex
    - reset_admin_password

guards:
  # Snapshot is pull-first. Pushing to production is disabled unless explicitly enabled.
  push_to_live: false
